{
  "name": "notebookflow",
  "version": "0.0.1",
  "private": true,
  "description": "n8n-style workflow orchestration for computational notebooks",
  "packageManager": "pnpm@10.33.4",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "clean": "turbo run clean && rimraf node_modules",
    "bootstrap": "pnpm install && pnpm bootstrap:engine && pnpm bootstrap:jupyter && turbo run build",
    "bootstrap:engine": "uv --project engine sync --all-extras",
    "bootstrap:jupyter": "uv --project engine add --optional dev jupyterlab && pnpm --filter @notebookflow/jupyterlab-extension add -D @jupyterlab/builder && pnpm --filter @notebookflow/jupyterlab-extension build:lab && pnpm jupyter:install",
    "engine": "uv --project engine run notebookflow",
    "jupyter:lab": "uv --project engine run jupyter lab examples/demo.ipynb",
    "jupyter:install": "node scripts/install-labextension.mjs",
    "start:web": "concurrently --names \"engine,web\" --prefix-colors \"yellow,cyan\" --kill-others-on-fail \"pnpm engine\" \"turbo run dev --filter=@notebookflow/web-app\"",
    "start:vscode": "pnpm --filter @notebookflow/vscode-extension build && node scripts/launch-vscode.mjs",
    "start:jupyter": "pnpm --filter @notebookflow/jupyterlab-extension build:lab && concurrently --names \"engine,lab\" --prefix-colors \"yellow,magenta\" --kill-others-on-fail \"pnpm engine\" \"pnpm jupyter:lab\""
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "concurrently": "^9.2.1",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.9",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@fortawesome/fontawesome-free",
      "esbuild",
      "@biomejs/biome"
    ]
  }
}
