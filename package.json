{
  "name": "notebookflow",
  "version": "0.0.1",
  "private": true,
  "description": "n8n-style workflow orchestration for computational notebooks",
  "packageManager": "pnpm@10.33.4",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@fortawesome/fontawesome-free", "esbuild"]
  }
}
