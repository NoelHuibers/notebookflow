{
  "name": "notebookflow",
  "version": "0.0.1",
  "private": true,
  "description": "n8n-style workflow orchestration for computational notebooks",
  "packageManager": "pnpm@10.33.4",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.9",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@fortawesome/fontawesome-free",
      "esbuild",
      "@biomejs/biome"
    ]
  }
}
