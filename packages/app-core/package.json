{
  "name": "@notebookflow/app-core",
  "version": "0.0.0",
  "description": "Host-agnostic workspace core: engine client, wire types, and pure pipeline/event helpers shared by the NotebookFlow surfaces",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@notebookflow/graph-canvas": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "react": "^18.3.1"
  }
}
