# ---------------------------------------------------------------------------
# Engine WebSocket URL used by the web-app (client-side, VITE_ prefix).
# Local dev (default if unset): ws://localhost:8765/ws
# Production (Fly.io): wss://notebookflow-engine.fly.dev/ws
# Vercel: set as an Environment Variable so it bakes into the bundle at build.
# ---------------------------------------------------------------------------
VITE_NOTEBOOKFLOW_ENGINE_URL=ws://localhost:8765/ws

# ---------------------------------------------------------------------------
# Auth (#59) — server-side secrets. NEVER prefix these with VITE_ (that would
# expose them to the browser bundle). Put real values in .env.local (gitignored)
# for local dev, and in the Vercel project's Environment Variables for prod.
# ---------------------------------------------------------------------------

# Turso (libSQL) database — sessions, accounts, JWKS live here.
# Create with: turso db create notebookflow && turso db show --url notebookflow
#              turso db tokens create notebookflow
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=

# BetterAuth. Generate a secret with: openssl rand -base64 32
# BETTER_AUTH_URL is this app's public origin (no trailing slash).
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5173

# OAuth providers. Callback URL for each: <BETTER_AUTH_URL>/api/auth/callback/<provider>
#   GitHub: https://github.com/settings/developers
#   Google: https://console.cloud.google.com/apis/credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Engine-side counterpart (set in the ENGINE's env, not here): the engine
# verifies BetterAuth JWTs against this app's JWKS endpoint —
#   NOTEBOOKFLOW_JWKS_URL=<BETTER_AUTH_URL>/api/auth/jwks
# ---------------------------------------------------------------------------
