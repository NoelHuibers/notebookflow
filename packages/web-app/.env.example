# Engine WebSocket URL used by the web-app.
# Local dev (default if unset): ws://localhost:8765/ws
# Production (Fly.io): wss://notebookflow-engine.fly.dev/ws
# Vercel: set this as an Environment Variable in the project settings so it
# bakes into the bundle at build time.
VITE_NOTEBOOKFLOW_ENGINE_URL=ws://localhost:8765/ws
