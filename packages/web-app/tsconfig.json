{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    // App, not a library: Vite builds it and graph-canvas is consumed as source
    // via the Vite alias, so no declaration emit is needed. Turning it off also
    // avoids TS2883 on better-auth's deeply-inferred (zod-referencing) types.
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*", "src/**/*.json"],
  "exclude": ["node_modules", "dist"],
  "references": [{ "path": "../app-core" }, { "path": "../graph-canvas" }]
}
