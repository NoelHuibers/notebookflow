{
  "name": "@notebookflow/web-app",
  "version": "0.0.0",
  "description": "Standalone NotebookFlow web app (no kernel, remote execution)",
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@notebookflow/graph-canvas": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5",
    "rimraf": "^6.1.3"
  }
}
