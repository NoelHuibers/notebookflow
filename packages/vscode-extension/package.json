{
  "name": "@notebookflow/vscode-extension",
  "version": "0.0.0",
  "displayName": "NotebookFlow",
  "description": "VS Code platform adapter for NotebookFlow",
  "publisher": "notebookflow",
  "engines": {
    "vscode": "^1.94.0"
  },
  "type": "module",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onNotebook:jupyter-notebook"
  ],
  "contributes": {
    "commands": [
      {
        "command": "notebookflow.openCanvas",
        "title": "NotebookFlow: Open Canvas",
        "category": "NotebookFlow",
        "icon": "$(circuit-board)"
      },
      {
        "command": "notebookflow.setLlmApiKey",
        "title": "NotebookFlow: Set LLM API Key",
        "category": "NotebookFlow"
      },
      {
        "command": "notebookflow.clearLlmApiKey",
        "title": "NotebookFlow: Clear LLM API Key",
        "category": "NotebookFlow"
      }
    ],
    "menus": {
      "notebook/toolbar": [
        {
          "command": "notebookflow.openCanvas",
          "group": "navigation@1",
          "when": "notebookType == 'jupyter-notebook'"
        }
      ]
    },
    "configuration": {
      "title": "NotebookFlow",
      "properties": {
        "notebookflow.enginePath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to a directory containing the NotebookFlow engine (a project with `uv run notebookflow` available). Leave blank to auto-discover an `engine/` directory under the workspace root."
        },
        "notebookflow.llm.provider": {
          "type": "string",
          "enum": [
            "anthropic",
            "openai",
            "moonshot",
            "deepseek",
            "qwen"
          ],
          "enumDescriptions": [
            "Anthropic (Claude)",
            "OpenAI (GPT)",
            "Moonshot (Kimi)",
            "DeepSeek",
            "Qwen"
          ],
          "default": "anthropic",
          "description": "LLM provider used for the AI features (Ask / Compose / Explain / node synthesis). The API key is stored separately via the \"NotebookFlow: Set LLM API Key\" command."
        },
        "notebookflow.llm.model": {
          "type": "string",
          "default": "",
          "description": "Model ID sent to the LLM provider. Leave blank to use the provider's default model."
        }
      }
    }
  },
  "files": [
    "dist",
    "dist-webview",
    "src",
    "webview"
  ],
  "scripts": {
    "build": "tsc -b && vite build",
    "build:host": "tsc -b",
    "build:webview": "vite build",
    "dev": "tsc -b --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist dist-webview .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@notebookflow/app-core": "workspace:*",
    "@notebookflow/graph-canvas": "workspace:*",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.8.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/vscode": "^1.118.0",
    "@vitejs/plugin-react": "^4.7.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  }
}
