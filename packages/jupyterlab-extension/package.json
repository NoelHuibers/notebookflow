{
  "name": "@notebookflow/jupyterlab-extension",
  "version": "0.0.0",
  "description": "JupyterLab platform adapter for NotebookFlow",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@notebookflow/graph-canvas": "workspace:*",
    "@jupyterlab/application": "^4.5.7",
    "@jupyterlab/notebook": "^4.5.7",
    "@jupyterlab/services": "^7.5.7",
    "@lumino/widgets": "^2.7.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "rimraf": "^6.1.3"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "../../engine/notebookflow/labextension"
  }
}
