{
  "name": "@notebookflow/jupyterlab-extension",
  "version": "0.0.0",
  "description": "JupyterLab platform adapter for NotebookFlow",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "schema",
    "src",
    "style"
  ],
  "scripts": {
    "build": "pnpm run build:css && tsc -b",
    "build:css": "tailwindcss -i style/tailwind.css -o style/index.css",
    "build:lab": "pnpm run build:css && tsc -b && uv --project ../../engine run jupyter labextension build .",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo ../../engine/notebookflow/labextension"
  },
  "dependencies": {
    "@jupyterlab/application": "^4.5.7",
    "@jupyterlab/apputils": "^4.6.7",
    "@jupyterlab/nbformat": "^4.5.7",
    "@jupyterlab/notebook": "^4.5.7",
    "@jupyterlab/services": "^7.5.7",
    "@jupyterlab/settingregistry": "^4.5.7",
    "@lumino/disposable": "^2.1.5",
    "@lumino/signaling": "^2.1.5",
    "@lumino/widgets": "^2.7.5",
    "@notebookflow/app-core": "workspace:*",
    "@notebookflow/graph-canvas": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.5.7",
    "@tailwindcss/cli": "^4.3.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "jupyterlab": {
    "extension": true,
    "schemaDir": "schema",
    "outputDir": "../../engine/notebookflow/labextension"
  }
}
