{
  "name": "@notebookflow/graph-canvas",
  "version": "0.0.0",
  "description": "Shared React + React Flow graph canvas with bidirectional notebook sync",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sync": {
      "types": "./dist/sync/index.d.ts",
      "import": "./dist/sync/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "dagre": "^0.8.5",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^19.2.7",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.54",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^19.2.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^19.2.7"
  }
}
