# Normalize all text files to LF in the repo, regardless of OS.
# Working-tree line endings still respect core.autocrlf locally.
* text=auto eol=lf

# Explicit binaries (don't try to diff or normalize line endings).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.otf   binary
*.parquet binary

# Notebooks: text but JSON; let GitHub render them and don't show in diffs.
*.ipynb linguist-language=Jupyter
*.ipynb -diff

# Lockfiles: generated, exclude from language stats and from PR diff noise.
pnpm-lock.yaml linguist-generated
uv.lock        linguist-generated
package-lock.json linguist-generated
yarn.lock      linguist-generated
