{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://notebookflow.dev/node_manifest.schema.json",
  "title": "NotebookFlow Node Manifest",
  "description": "Public extension contract for a single node package.",
  "type": "object",
  "required": ["id", "name", "tag", "inputs", "outputs"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
      "description": "Globally unique node id, e.g. notebookflow.parse_csv"
    },
    "name": {
      "type": "string",
      "description": "Human-readable node name shown on the canvas."
    },
    "tag": {
      "type": "string",
      "enum": ["input", "transform", "output", "ai", "io"]
    },
    "version": {
      "type": "string",
      "default": "0.0.0"
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "generationMode": {
      "type": "string",
      "enum": ["template", "llm"],
      "default": "template"
    },
    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/Port" }
    },
    "outputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/Port" }
    },
    "template": {
      "type": "string",
      "description": "Cell-source template inserted when the node is added to a notebook."
    },
    "configFields": {
      "type": "array",
      "items": { "$ref": "#/$defs/ConfigField" },
      "default": []
    }
  },
  "$defs": {
    "Port": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["dataframe", "json", "text", "fileref", "any"],
          "default": "any"
        },
        "required": { "type": "boolean", "default": true }
      }
    },
    "ConfigOption": {
      "type": "object",
      "required": ["value", "label"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": "string" },
        "label": { "type": "string" }
      }
    },
    "ConfigField": {
      "type": "object",
      "required": ["key", "label"],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "label": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["text", "textarea", "select"],
          "default": "text"
        },
        "description": {
          "type": "string",
          "default": ""
        },
        "placeholder": {
          "type": "string",
          "default": ""
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "defaultValue": {
          "type": "string",
          "default": ""
        },
        "options": {
          "type": "array",
          "items": { "$ref": "#/$defs/ConfigOption" },
          "default": []
        }
      }
    }
  }
}
