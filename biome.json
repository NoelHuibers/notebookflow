{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/dist",
      "!**/dist-webview",
      "!**/node_modules",
      "!**/.turbo",
      "!**/coverage",
      "!**/*.tsbuildinfo",
      "!**/pnpm-lock.yaml",
      "!**/*.css",
      "!**/*.html",
      "!engine",
      "!node-library-spec/notebookflow-node-hello"
    ]
  },
  "formatter": {
    "enabled": true,
    "useEditorconfig": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf",
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.mjs",
      "**/*.cjs",
      "**/*.json",
      "**/*.jsonc"
    ]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "bracketSameLine": false
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "css": {
    "formatter": {
      "enabled": false
    },
    "linter": {
      "enabled": false
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "noUnusedFunctionParameters": "error",
        "noUnusedPrivateClassMembers": "error",
        "useExhaustiveDependencies": "error",
        "useHookAtTopLevel": "error",
        "noUndeclaredDependencies": "off"
      },
      "style": {
        "useImportType": "error",
        "useExportType": "error",
        "useConst": "error",
        "useTemplate": "error",
        "useNodejsImportProtocol": "error",
        "useShorthandFunctionType": "error",
        "useShorthandAssign": "error",
        "useSelfClosingElements": "error",
        "useSingleVarDeclarator": "error",
        "useNumberNamespace": "error",
        "noNonNullAssertion": "error",
        "noParameterAssign": "error",
        "noUselessElse": "error",
        "noInferrableTypes": "error"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noConsole": { "level": "warn", "options": { "allow": ["error", "warn"] } },
        "useAwait": "off",
        "noDoubleEquals": "error",
        "noArrayIndexKey": "error"
      },
      "complexity": {
        "noBannedTypes": "error",
        "noStaticOnlyClass": "off",
        "noUselessConstructor": "off",
        "useArrowFunction": "error",
        "useOptionalChain": "error",
        "noForEach": "off"
      },
      "performance": {
        "noBarrelFile": "off",
        "noReExportAll": "off"
      },
      "a11y": {
        "useButtonType": "error",
        "useAltText": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/components/ui/**/*.{ts,tsx}"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.test.{ts,tsx}"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          },
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.config.{js,ts,mjs,cjs}", "**/vite.config.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "error"
          }
        }
      }
    },
    {
      "includes": ["scripts/**/*.{js,mjs,cjs}"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}
