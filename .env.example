# NotebookFlow local engine settings

# AI node synthesis
OPENAI_API_KEY=your-openai-api-key

# Optional engine-specific overrides
# NOTEBOOKFLOW_OPENAI_API_KEY=your-openai-api-key
# NOTEBOOKFLOW_OPENAI_MODEL=gpt-4o-mini
# NOTEBOOKFLOW_OPENAI_BASE_URL=https://api.openai.com/v1

# Auth (#59). The engine authenticates requests by either:
#  - a static shared secret (self-host / single-tenant), or
#  - a BetterAuth JWT verified against the web app's JWKS (multi-tenant).
# Leave both unset for open local/single-user dev.
# NOTEBOOKFLOW_AUTH_TOKEN=some-long-random-self-host-secret
# NOTEBOOKFLOW_JWKS_URL=https://<your-web-app-origin>/api/auth/jwks
# Optional JWT claim checks (recommended in production):
# NOTEBOOKFLOW_JWT_ISSUER=https://<your-web-app-origin>
# NOTEBOOKFLOW_JWT_AUDIENCE=https://<your-web-app-origin>